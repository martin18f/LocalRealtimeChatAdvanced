<Window x:Class="LocalRealtimeChat.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local Realtime Chat Advanced"
        Height="640"
        Width="960"
        MinHeight="540"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="14"
                Padding="18"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Local Realtime Chat Advanced"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#EEF2FF"
                        CornerRadius="999"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="#6366F1"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"/>

                        <TextBlock x:Name="StatusTextBlock"
                                   Text="Disconnected"
                                   Foreground="#4338CA"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="14"
                    Padding="14"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F9FAFB"
                            CornerRadius="10"
                            Padding="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Meno:"
                                       VerticalAlignment="Center"
                                       Foreground="#374151"
                                       FontWeight="SemiBold"
                                       Margin="0,0,8,0"/>

                            <TextBox x:Name="UsernameTextBox"
                                     Width="190"
                                     Height="34"
                                     Text="Martin"
                                     VerticalContentAlignment="Center"
                                     Padding="8,0"
                                     BorderBrush="#D1D5DB"
                                     Margin="0,0,10,0"/>

                            <Button x:Name="ConnectButton"
                                    Width="115"
                                    Height="34"
                                    Content="Pripojiť"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Click="ConnectButton_Click"/>
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="MessagesListBox"
                             Grid.Row="2"
                             BorderThickness="0"
                             Background="#F9FAFB"
                             Padding="12"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Border x:Name="MessageBubble"
                                            HorizontalAlignment="Left"
                                            MaxWidth="430"
                                            Background="White"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="12,9">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Text="{Binding Username}"
                                                           FontWeight="Bold"
                                                           FontSize="12"
                                                           Foreground="#374151"
                                                           DockPanel.Dock="Left"/>

                                                <TextBlock Text="{Binding SentAtText}"
                                                           FontSize="11"
                                                           Foreground="#9CA3AF"
                                                           HorizontalAlignment="Right"/>
                                            </DockPanel>

                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="14"
                                                       Foreground="#111827"
                                                       TextWrapping="Wrap"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsOwnMessage}" Value="True">
                                        <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Right"/>
                                        <Setter TargetName="MessageBubble" Property="Background" Value="#EEF2FF"/>
                                        <Setter TargetName="MessageBubble" Property="BorderBrush" Value="#C7D2FE"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="14"
                    Padding="14"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Online používatelia"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>

                        <TextBlock x:Name="OnlineCountTextBlock"
                                   Text="0 online"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <ListBox x:Name="OnlineUsersListBox"
                             Grid.Row="2"
                             BorderThickness="0"
                             Background="#F9FAFB"
                             FontSize="14"
                             Padding="8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        CornerRadius="9"
                                        Padding="8"
                                        Margin="0,4"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="9"
                                                 Height="9"
                                                 Fill="#22C55E"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>

                                        <TextBlock Text="{Binding}"
                                                   Foreground="#111827"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="White"
                CornerRadius="14"
                Padding="12"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TypingTextBlock"
                           Grid.Row="0"
                           Text=""
                           FontSize="12"
                           Foreground="#6B7280"
                           MinHeight="16"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="MessageTextBox"
                             Grid.Column="0"
                             Height="42"
                             VerticalContentAlignment="Center"
                             IsEnabled="False"
                             Padding="12,0"
                             BorderBrush="#D1D5DB"
                             TextChanged="MessageTextBox_TextChanged"
                             PreviewKeyDown="MessageTextBox_PreviewKeyDown"/>

                    <Button x:Name="SendButton"
                            Grid.Column="2"
                            Height="42"
                            Content="Odoslať"
                            IsEnabled="False"
                            Style="{StaticResource RoundedButtonStyle}"
                            Click="SendButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>